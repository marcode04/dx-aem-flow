{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "COPILOT_CUSTOM_INSTRUCTIONS_DIRS": ".claude/rules"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(ps:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(date:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(test:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(cd:*)",
      "Bash(wait)",
      "Bash(mvn*)",
      "Bash(bash .claude/**:*)",
      "Bash(bash */.claude/**)",
      "Edit(specs/**)",
      "Write(specs/**)",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.x.ai)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:genai.owasp.org)",
      "WebFetch(domain:support.claude.com)",
      "WebFetch(domain:docs.github.com)",
      "mcp__ide__getDiagnostics",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ]
  }
}
